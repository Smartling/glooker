# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=glooker

# GitHub
GITHUB_TOKEN=ghp_your_personal_access_token
# Required scopes: repo (for private repos) or public_repo (for public only)
# Generate at: https://github.com/settings/tokens

# Smartling AI Proxy
SMARTLING_BASE_URL=https://api.smartling.com
SMARTLING_ACCOUNT_UID=your_account_uid
SMARTLING_USER_IDENTIFIER=your_user_identifier
SMARTLING_USER_SECRET=your_user_secret

# LLM model via AI Proxy (OpenAI-compatible publisher/model format)
# Options: anthropic/claude-sonnet-4-20250514, openai/gpt-4o-2024-08-06, etc.
LLM_MODEL=anthropic/claude-sonnet-4-20250514

# Concurrency for LLM commit analysis (start low, increase if proxy allows)
LLM_CONCURRENCY=5
