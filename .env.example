# =============================================================================
# Glooker Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
# Fine-grained personal access token
# Required permissions: Contents (read), Pull requests (read), Metadata (read),
#                       Members (read) [organization]
# Generate at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_your_token_here

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
# Choose your LLM provider: openai, anthropic, openai-compatible, or smartling
LLM_PROVIDER=openai

# API key for your provider (not needed for smartling or some local models)
LLM_API_KEY=sk-your-api-key-here

# Model to use (defaults: gpt-4o for openai, claude-sonnet-4-20250514 for anthropic)
LLM_MODEL=gpt-4o

# Custom base URL (only for openai-compatible provider, e.g. http://localhost:11434/v1 for Ollama)
# LLM_BASE_URL=

# Max concurrent LLM requests (start low, increase if your provider allows)
LLM_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Database (optional — defaults to SQLite, zero config)
# -----------------------------------------------------------------------------
# DB_TYPE=sqlite          # default — stores data in ./glooker.db
# SQLITE_PATH=./glooker.db

# Uncomment below for MySQL:
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=glooker

# -----------------------------------------------------------------------------
# Smartling AI Proxy (only if LLM_PROVIDER=smartling)
# -----------------------------------------------------------------------------
# SMARTLING_BASE_URL=https://api.smartling.com
# SMARTLING_ACCOUNT_UID=your_account_uid
# SMARTLING_USER_IDENTIFIER=your_user_identifier
# SMARTLING_USER_SECRET=your_user_secret
