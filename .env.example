# =============================================================================
# Glooker Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
# Fine-grained personal access token
# Required permissions: Contents (read), Pull requests (read), Metadata (read),
#                       Members (read) [organization]
# Generate at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_your_token_here

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
# Choose your LLM provider: openai, anthropic, openai-compatible, smartling, or bedrock
LLM_PROVIDER=openai

# API key for your provider (not needed for smartling or some local models)
LLM_API_KEY=sk-your-api-key-here

# Model to use (defaults: gpt-4o for openai, claude-sonnet-4-20250514 for anthropic, us.anthropic.claude-sonnet-4-6 for bedrock)
LLM_MODEL=gpt-4o

# Custom base URL (only for openai-compatible provider, e.g. http://localhost:11434/v1 for Ollama)
# LLM_BASE_URL=

# Max concurrent LLM requests (start low, increase if your provider allows)
LLM_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Database (optional — defaults to SQLite, zero config)
# -----------------------------------------------------------------------------
# DB_TYPE=sqlite          # default — stores data in ./glooker.db
# SQLITE_PATH=./glooker.db

# Uncomment below for MySQL:
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=glooker

# -----------------------------------------------------------------------------
# Smartling AI Proxy (only if LLM_PROVIDER=smartling)
# -----------------------------------------------------------------------------
# SMARTLING_BASE_URL=https://api.smartling.com
# SMARTLING_ACCOUNT_UID=your_account_uid
# SMARTLING_USER_IDENTIFIER=your_user_identifier
# SMARTLING_USER_SECRET=your_user_secret

# -----------------------------------------------------------------------------
# AWS Bedrock (only if LLM_PROVIDER=bedrock)
# -----------------------------------------------------------------------------
# Uses the default AWS credential provider chain.
# For SSO: run `aws sso login --profile your-profile` first.
# AWS_PROFILE=your-profile
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Prompt Templates (optional — defaults shown)
# -----------------------------------------------------------------------------
# Directory containing prompt template files
# PROMPTS_DIR=./prompts

# -----------------------------------------------------------------------------
# Per-Service LLM Settings (optional — defaults shown)
# -----------------------------------------------------------------------------
# Commit Analyzer
# ANALYZER_TEMPERATURE=0
# ANALYZER_MAX_TOKENS=256

# Chat Agent (conversational assistant)
# CHAT_AGENT_TEMPERATURE=0.3
# CHAT_AGENT_MAX_TOKENS=1500
# CHAT_AGENT_MAX_ITERATIONS=5

# Developer Summary
# SUMMARY_TEMPERATURE=0.7
# SUMMARY_MAX_TOKENS=512

# Report Highlights (report-over-report comparison)
# HIGHLIGHTS_TEMPERATURE=0.5
# HIGHLIGHTS_MAX_TOKENS=512

# LLM Connection Test
# LLM_TEST_TEMPERATURE=0
# LLM_TEST_MAX_TOKENS=32
