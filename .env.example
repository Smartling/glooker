# =============================================================================
# Glooker Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
# Required — Fine-grained personal access token
# Permissions needed: Contents (read), Pull requests (read), Metadata (read),
#                     Members (read) [organization]
# Generate at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_your_token_here

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
# Optional (default: openai) — Choose your LLM backend
LLM_PROVIDER=openai

# Required when LLM_PROVIDER is openai or anthropic — API key for your provider
LLM_API_KEY=sk-your-api-key-here

# Optional (default: gpt-4o for openai, claude-sonnet-4-20250514 for anthropic, us.anthropic.claude-sonnet-4-6 for bedrock)
LLM_MODEL=gpt-4o

# Required when LLM_PROVIDER=openai-compatible — Custom base URL (e.g. http://localhost:11434/v1 for Ollama)
# LLM_BASE_URL=

# Optional (default: 5) — Max concurrent LLM requests
LLM_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Optional (default: sqlite) — Database backend
# DB_TYPE=sqlite          # stores data in ./glooker.db, no setup needed
# SQLITE_PATH=./glooker.db

# Required when DB_TYPE=mysql:
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=glooker

# -----------------------------------------------------------------------------
# Smartling AI Proxy (required when LLM_PROVIDER=smartling)
# -----------------------------------------------------------------------------
# SMARTLING_BASE_URL=https://api.smartling.com
# SMARTLING_ACCOUNT_UID=your_account_uid
# SMARTLING_USER_IDENTIFIER=your_user_identifier
# SMARTLING_USER_SECRET=your_user_secret

# -----------------------------------------------------------------------------
# AWS Bedrock (required when LLM_PROVIDER=bedrock)
# -----------------------------------------------------------------------------
# Uses the default AWS credential provider chain.
# For SSO: run `aws sso login --profile your-profile` first.
# AWS_PROFILE=your-profile
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Prompt Templates
# -----------------------------------------------------------------------------
# Optional (default: ./prompts) — Directory containing prompt template files
# PROMPTS_DIR=./prompts

# -----------------------------------------------------------------------------
# Per-Service LLM Settings (all optional — defaults shown)
# -----------------------------------------------------------------------------
# Commit Analyzer
# ANALYZER_TEMPERATURE=0
# ANALYZER_MAX_TOKENS=256

# Chat Agent (conversational assistant)
# CHAT_AGENT_TEMPERATURE=0.3
# CHAT_AGENT_MAX_TOKENS=1500
# CHAT_AGENT_MAX_ITERATIONS=5

# Developer Summary
# SUMMARY_TEMPERATURE=0.7
# SUMMARY_MAX_TOKENS=512

# Report Highlights (report-over-report comparison)
# HIGHLIGHTS_TEMPERATURE=0.5
# HIGHLIGHTS_MAX_TOKENS=512

# LLM Connection Test
# LLM_TEST_TEMPERATURE=0
# LLM_TEST_MAX_TOKENS=32

# -----------------------------------------------------------------------------
# Jira (optional — for tracking resolved issues per developer)
# -----------------------------------------------------------------------------
# Optional (default: false) — Enable Jira integration
# JIRA_ENABLED=false
# Required when JIRA_ENABLED=true:
# JIRA_HOST=mycompany.atlassian.net
# JIRA_USERNAME=your-email@company.com
# JIRA_API_TOKEN=your-jira-api-token
# Optional (default: 3)
# JIRA_API_VERSION=3
# Optional — Comma-separated Jira project keys to filter
# JIRA_PROJECTS=
# JIRA_STORY_POINTS_FIELDS=
# Comma-separated Jira field IDs for story points (instance-specific, no universal default).
# To find yours: GET https://<JIRA_HOST>/rest/api/3/field
# Filter results by fields whose name contains "story" or "point", then use the id value.
# Example: JIRA_STORY_POINTS_FIELDS=customfield_10016

# -----------------------------------------------------------------------------
# Authentication (optional — for ALB OIDC deployments)
# -----------------------------------------------------------------------------
# Optional (default: false) — Enable user identity extraction from ALB OIDC header
# AUTH_ENABLED=false
# Optional (default: x-amzn-oidc-data) — Header name containing the OIDC JWT
# AUTH_HEADER=x-amzn-oidc-data
